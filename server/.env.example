# MongoDB Atlas ya local MongoDB ka connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/property-hub

# Google Cloud Console se same Client ID jo frontend mein use kiya hai
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Apna JWT sign karne ke liye ek random secret (kisi bhi lambi random string se generate kar lein)
JWT_SECRET=change_this_to_a_long_random_secret

PORT=5000
